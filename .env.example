# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma — Supabase connection string
# Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
SHARE_LINK_SECRET=dev-secret-change-in-prod-min-32-chars

# ── CBAM Data ─────────────────────────────────────────────────────────────────
CBAM_DATA_VERSION=20260204
NEXT_PUBLIC_SUPABASE_URL=https://qhqyyaosykzldbeuyjmq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_s13BoNzsgO49zQgumVNYFQ_0ox4Xo3g
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.qhqyyaosykzldbeuyjmq:[Greenlink*123!!!]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
