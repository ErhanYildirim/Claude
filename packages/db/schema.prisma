generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Tenant ────────────────────────────────────────────────────────────────────
model Tenant {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  slug          String               @unique
  logoUrl       String?              @map("logo_url")
  brandColor    String?              @map("brand_color")
  timezone      String               @default("Europe/Istanbul") @map("timezone")
  plan          String               @default("free") @map("plan")
  disabled      Boolean              @default(false) @map("disabled")
  planSeats     Int                  @default(3) @map("plan_seats")
  planInstalls  Int                  @default(5) @map("plan_installs")
  planExpires   DateTime?            @map("plan_expires")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  installations           Installation[]
  shareLinks              ShareLink[]
  auditLogs               AuditLog[]
  members                 TenantMember[]
  apiKeys                 ApiKey[]
  webhooks                WebhookSubscription[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  memberInvites           MemberInvite[]
  emissionTargets         EmissionTarget[]

  @@map("tenants")
}

// ── TenantMember (RBAC) ───────────────────────────────────────────────────────
model TenantMember {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid

  role      String   @default("viewer")         // owner | admin | analyst | viewer
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_members")
}

// ── Installation (Tesis) ──────────────────────────────────────────────────────
model Installation {
  id              String  @id @default(uuid()) @db.Uuid
  tenantId        String  @map("tenant_id") @db.Uuid
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  facilityName    String  @map("facility_name")
  operator        String
  facilityCountry String  @map("facility_country")
  facilityRef     String? @map("facility_ref")
  sector          String  @default("steel") @map("sector")  // steel|aluminium|cement|fertilizer|electricity

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  periods         ReportingPeriod[]
  emissionTargets EmissionTarget[]
  cbamProducts    CbamProduct[]

  @@index([tenantId])
  @@map("installations")
}

// ── ReportingPeriod (Üretim Dönemi) ──────────────────────────────────────────
model ReportingPeriod {
  id             String       @id @default(uuid()) @db.Uuid
  installationId String       @map("installation_id") @db.Uuid
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  periodName   String   @map("period_name")
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date")   @db.Date
  reportYear   Int      @map("report_year")

  importCountry   String @map("import_country")
  cnCode          String @map("cn_code")
  prodVolumeTonne Float  @map("prod_volume_tonne")
  scope2Exempt    Boolean @default(false) @map("scope2_exempt")

  scope1DirectTco2 Float   @map("scope1_direct_tco2")
  scope1Quality    String  @map("scope1_quality")
  scope1AuditNote  String? @map("scope1_audit_note")

  electricityKwh    Float   @map("electricity_kwh")
  electricitySource String  @map("electricity_source")
  baselineEf        Float   @map("baseline_ef")
  renewableEf       Float   @map("renewable_ef")
  matchingRatePct   Float   @map("matching_rate_pct")
  gecConnected      Boolean @default(false) @map("gec_connected")

  carbonPriceEur Float? @map("carbon_price_eur")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  result      EmbeddedEmission?
  cfeResult   CFEMatchingResult?
  hourlyData  HourlyConsumption[]

  @@index([installationId])
  @@map("reporting_periods")
}

// ── EmbeddedEmission (SEE Sonucu) ─────────────────────────────────────────────
model EmbeddedEmission {
  id       String          @id @default(uuid()) @db.Uuid
  periodId String          @unique @map("period_id") @db.Uuid
  period   ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  scope2BaselineTco2  Float  @map("scope2_baseline_tco2")
  scope2VoltfoxTco2   Float  @map("scope2_voltfox_tco2")
  reductionTco2       Float  @map("reduction_tco2")
  reductionPct        Float  @map("reduction_pct")

  seeBaseline Float  @map("see_baseline")
  seeVoltfox  Float  @map("see_voltfox")

  defaultSee          Float? @map("default_see")
  savingsVsDefaultEur Float? @map("savings_vs_default_eur")

  calcEngineVersion String @map("calc_engine_version")
  calcMethodology   String @default("EU_2023_1773_AnnexIV_MethodA") @map("calc_methodology")
  efDataVersion     String @map("ef_data_version")

  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@map("embedded_emissions")
}

// ── CFEMatchingResult (24/7 CFE Eşleştirme Sonucu) ───────────────────────────
model CFEMatchingResult {
  id       String          @id @default(uuid()) @db.Uuid
  periodId String          @unique @map("period_id") @db.Uuid
  period   ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  totalConsumptionKwh Float @map("total_consumption_kwh")
  totalProductionKwh  Float @map("total_production_kwh")
  totalMatchedKwh     Float @map("total_matched_kwh")
  cfeScore            Float @map("cfe_score")
  ppaSurplusKwh       Float @map("ppa_surplus_kwh")
  ppaDeficitKwh       Float @map("ppa_deficit_kwh")
  matchedHours        Int   @map("matched_hours")
  partialHours        Int   @map("partial_hours")
  unmatchedHours      Int   @map("unmatched_hours")

  monthlyBreakdown  Json   @map("monthly_breakdown")
  gecDataVersion    String @map("gec_data_version")
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  @@map("cfe_matching_results")
}

// ── ShareLink ─────────────────────────────────────────────────────────────────
model ShareLink {
  id             String    @id @default(uuid()) @db.Uuid
  jti            String    @unique
  tenantId       String    @map("tenant_id") @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installationId String    @map("installation_id") @db.Uuid
  periodId       String    @map("period_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  password       String?   // scrypt hash: salt:hash
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([jti])
  @@map("share_links")
}

// ── ApiKey (Data Service B2B) ─────────────────────────────────────────────────
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name       String
  keyHash    String    @unique @map("key_hash")
  prefix     String
  scopes     String[]  @default([])
  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("api_keys")
}

// ── WebhookSubscription ───────────────────────────────────────────────────────
model WebhookSubscription {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url        String
  events     String[]
  secretHash String    @map("secret_hash")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt    @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_subscriptions")
}

// ── WebhookDelivery ───────────────────────────────────────────────────────────
model WebhookDelivery {
  id             String              @id @default(uuid()) @db.Uuid
  subscriptionId String              @map("subscription_id") @db.Uuid
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  event          String
  payload        Json
  status         String    @default("pending")
  attempts       Int       @default(0)
  responseStatus Int?      @map("response_status")
  nextAttemptAt  DateTime? @map("next_attempt_at")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

// ── AuditLog ──────────────────────────────────────────────────────────────────
model AuditLog {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String? @map("user_id") @db.Uuid

  action     String
  resource   String
  resourceId String? @map("resource_id")
  payload    Json?
  ipAddress  String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Notification ─────────────────────────────────────────────────────────────
model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id") @db.Uuid

  type       String
  title      String
  body       String?
  resource   String?
  resourceId String?  @map("resource_id") @db.Uuid
  read       Boolean  @default(false)

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ── NotificationPreference ────────────────────────────────────────────────────
model NotificationPreference {
  tenantId       String  @map("tenant_id") @db.Uuid
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String  @map("user_id") @db.Uuid

  calculationDone Boolean @default(true)  @map("calculation_done")
  cfeDone         Boolean @default(true)  @map("cfe_done")
  memberInvited   Boolean @default(true)  @map("member_invited")
  periodCreated   Boolean @default(true)  @map("period_created")
  emailEnabled    Boolean @default(false) @map("email_enabled")

  @@id([tenantId, userId])
  @@map("notification_preferences")
}

// ── EfImportLog ──────────────────────────────────────────────────────────────
model EfImportLog {
  id        String   @id @default(uuid()) @db.Uuid
  year      Int
  zoneId    String?  @map("zone_id")
  rowsAdded Int      @default(0) @map("rows_added")
  status    String   @default("ok")   // ok | error | partial
  message   String?
  startedAt DateTime @map("started_at")
  endedAt   DateTime @map("ended_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ef_import_logs")
}

// ── MemberInvite ─────────────────────────────────────────────────────────────
model MemberInvite {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email     String
  role      String    @default("viewer")
  token     String    @unique @default(uuid())
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("member_invites")
}

// ── EmissionTarget (Yıllık emisyon azaltım hedefleri) ────────────────────────
model EmissionTarget {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installationId String?       @map("installation_id") @db.Uuid
  installation   Installation? @relation(fields: [installationId], references: [id], onDelete: Cascade)
  year           Int
  metric         String        @default("see_voltfox") // see_voltfox | scope2_tco2 | reduction_pct
  targetValue    Decimal       @map("target_value") @db.Decimal(18, 6)
  baselineValue  Decimal?      @map("baseline_value") @db.Decimal(18, 6)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, installationId, year, metric])
  @@index([tenantId, year])
  @@map("emission_targets")
}

// ── CarbonPrice (EU ETS / CBAM fiyat geçmişi) ────────────────────────────────
model CarbonPrice {
  id          String   @id @default(uuid()) @db.Uuid
  date        DateTime @db.Date
  etsPriceEur Decimal  @map("ets_price_eur") @db.Decimal(10, 4)
  cbamEstEur  Decimal? @map("cbam_est_eur")  @db.Decimal(10, 4)
  source      String   @default("manual")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date, source])
  @@index([date(sort: Desc)])
  @@map("carbon_prices")
}

// ── CbamProduct (Tesis altındaki CBAM ürün tanımı) ───────────────────────────
model CbamProduct {
  id                   String       @id @default(uuid()) @db.Uuid
  tenantId             String       @map("tenant_id") @db.Uuid
  installationId       String       @map("installation_id") @db.Uuid
  installation         Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  productName          String  @map("product_name")
  cnCode               String? @map("cn_code")           // CBAM CN kodu: 7206, 7601, 2523, vb.
  description          String?
  unit                 String  @default("tonne") @map("unit") // tonne | MWh | kg
  isCbamScope          Boolean @default(true) @map("is_cbam_scope")

  // "facility" → tesisin toplam yenilenebilir üretimi ürünler arasında orantılı dağıtılır
  // "band"     → her üretim bandı kendi enerji sayacına sahip, doğrudan atanır
  energyAllocationMode String  @default("facility") @map("energy_allocation_mode")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  productPeriods CbamProductPeriod[]

  @@index([installationId])
  @@index([tenantId])
  @@map("cbam_products")
}

// ── CbamProductPeriod (Ürün bazlı dönem verisi + hesaplama sonucu) ───────────
model CbamProductPeriod {
  id            String      @id @default(uuid()) @db.Uuid
  cbamProductId String      @map("cbam_product_id") @db.Uuid
  cbamProduct   CbamProduct @relation(fields: [cbamProductId], references: [id], onDelete: Cascade)

  reportYear  Int      @map("report_year")
  periodName  String   @map("period_name")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date")   @db.Date

  // Üretim
  productionVolumeTonne Decimal @map("production_volume_tonne") @db.Decimal(18, 4)

  // Scope 1 (doğrudan yakıt emisyonu vb.)
  scope1DirectTco2 Decimal @default(0) @map("scope1_direct_tco2") @db.Decimal(18, 4)
  scope1AuditNote  String? @map("scope1_audit_note")

  // ── BAND modu: üretim bandına özel sayaç verisi ──────────────────────────
  bandElectricityKwh Decimal? @map("band_electricity_kwh") @db.Decimal(18, 2)
  bandRenewableKwh   Decimal? @map("band_renewable_kwh")   @db.Decimal(18, 2)

  // ── FACILITY modu: tesis toplamları + bu ürünün payı ─────────────────────
  facilityTotalKwh     Decimal? @map("facility_total_kwh")     @db.Decimal(18, 2) // tüm tesis toplam elektrik
  facilityRenewableKwh Decimal? @map("facility_renewable_kwh") @db.Decimal(18, 2) // tüm tesis toplam yenilenebilir
  productShareKwh      Decimal? @map("product_share_kwh")      @db.Decimal(18, 2) // bu ürün bandının elektrik payı

  // Yenilenebilir kaynak
  // "solar" | "wind_onshore" | "wind_offshore" | "hydro" | "nuclear" | "biomass" | "geothermal"
  renewableSource   String?  @map("renewable_source")
  renewableSourceEf Decimal? @map("renewable_source_ef") @db.Decimal(10, 6) // tCO₂/MWh (auto-filled)

  // Referans EF'ler — eşleşmeyen kısım için
  cbamDefaultEf Decimal? @map("cbam_default_ef") @db.Decimal(10, 6) // CBAM Annex IV elektrik EF'i (tCO₂/MWh)
  countryGridEf Decimal? @map("country_grid_ef") @db.Decimal(10, 6) // Ülke yıllık ortalama EF (tCO₂/MWh)

  // ── Hesaplama sonuçları (calculate endpoint tarafından doldurulur) ────────
  allocatedElecKwh      Decimal? @map("allocated_elec_kwh")       @db.Decimal(18, 2)
  allocatedRenewKwh     Decimal? @map("allocated_renew_kwh")      @db.Decimal(18, 2)
  matchedKwh            Decimal? @map("matched_kwh")              @db.Decimal(18, 2)
  unmatchedKwh          Decimal? @map("unmatched_kwh")            @db.Decimal(18, 2)
  matchedIndirectTco2   Decimal? @map("matched_indirect_tco2")    @db.Decimal(18, 6)
  unmatchedIndirectTco2 Decimal? @map("unmatched_indirect_tco2")  @db.Decimal(18, 6)
  totalIndirectTco2     Decimal? @map("total_indirect_tco2")      @db.Decimal(18, 6)
  totalEmbeddedTco2     Decimal? @map("total_embedded_tco2")      @db.Decimal(18, 6)
  see                   Decimal? @map("see")                      @db.Decimal(18, 8) // tCO₂/tonne
  effectiveEf           Decimal? @map("effective_ef")             @db.Decimal(10, 6) // ağırlıklı ort. tCO₂/MWh
  unmatchedEfUsed       Decimal? @map("unmatched_ef_used")        @db.Decimal(10, 6)
  unmatchedEfSource     String?  @map("unmatched_ef_source")      // "cbam_default" | "country_grid"

  calculatedAt DateTime? @map("calculated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([cbamProductId, reportYear])
  @@index([cbamProductId])
  @@map("cbam_product_periods")
}

// ── HourlyConsumption (Saatlik Tüketim Verisi) ───────────────────────────────
model HourlyConsumption {
  id             String          @id @default(uuid()) @db.Uuid
  periodId       String          @map("period_id") @db.Uuid
  period         ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  hour           DateTime        @map("hour")           // ISO 8601 UTC, saat başı
  consumptionKwh Float           @map("consumption_kwh")
  source         String          @default("csv")        // csv | osos | amr | manual
  quality        String          @default("measured")   // measured | estimated | interpolated

  createdAt      DateTime        @default(now()) @map("created_at")

  @@unique([periodId, hour])
  @@index([periodId])
  @@index([hour])
  @@map("hourly_consumptions")
}
