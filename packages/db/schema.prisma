generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Tenant ────────────────────────────────────────────────────────────────────
model Tenant {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  slug          String               @unique
  logoUrl       String?              @map("logo_url")
  brandColor    String?              @map("brand_color")
  timezone      String               @default("Europe/Istanbul") @map("timezone")
  plan          String               @default("free") @map("plan")
  disabled      Boolean              @default(false) @map("disabled")
  planSeats     Int                  @default(3) @map("plan_seats")
  planInstalls  Int                  @default(5) @map("plan_installs")
  planExpires   DateTime?            @map("plan_expires")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  installations           Installation[]
  cbamFacilities          CbamFacility[]
  shareLinks              ShareLink[]
  auditLogs               AuditLog[]
  members                 TenantMember[]
  apiKeys                 ApiKey[]
  webhooks                WebhookSubscription[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  memberInvites           MemberInvite[]
  emissionTargets         EmissionTarget[]
  integrationConfigs      IntegrationConfig[]
  esgGraphs               EsgPlaygroundGraph[]

  @@map("tenants")
}

// ── TenantMember (RBAC) ───────────────────────────────────────────────────────
model TenantMember {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid

  role      String   @default("viewer")         // owner | admin | analyst | viewer
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_members")
}

// ── Installation (Tesis) ──────────────────────────────────────────────────────
model Installation {
  id              String  @id @default(uuid()) @db.Uuid
  tenantId        String  @map("tenant_id") @db.Uuid
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  facilityName    String  @map("facility_name")
  operator        String
  facilityCountry String  @map("facility_country")
  facilityRef     String? @map("facility_ref")
  sector          String  @default("steel") @map("sector")  // steel|aluminium|cement|fertilizer|electricity|hydrogen|chemicals

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  periods         ReportingPeriod[]
  emissionTargets EmissionTarget[]

  @@index([tenantId])
  @@map("installations")
}

// ── ReportingPeriod (Üretim Dönemi) ──────────────────────────────────────────
model ReportingPeriod {
  id             String       @id @default(uuid()) @db.Uuid
  installationId String       @map("installation_id") @db.Uuid
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  periodName   String   @map("period_name")
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date")   @db.Date
  reportYear   Int      @map("report_year")

  importCountry   String @map("import_country")
  cnCode          String @map("cn_code")
  prodVolumeTonne Float  @map("prod_volume_tonne")
  scope2Exempt    Boolean @default(false) @map("scope2_exempt")

  scope1DirectTco2 Float   @map("scope1_direct_tco2")
  scope1Quality    String  @map("scope1_quality")
  scope1AuditNote  String? @map("scope1_audit_note")

  electricityKwh    Float   @map("electricity_kwh")
  electricitySource String  @map("electricity_source")
  baselineEf        Float   @map("baseline_ef")
  renewableEf       Float   @map("renewable_ef")
  matchingRatePct   Float   @map("matching_rate_pct")
  gecConnected      Boolean @default(false) @map("gec_connected")

  carbonPriceEur Float? @map("carbon_price_eur")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  result      EmbeddedEmission?
  cfeResult   CFEMatchingResult?
  hourlyData  HourlyConsumption[]

  @@index([installationId])
  @@map("reporting_periods")
}

// ── EmbeddedEmission (SEE Sonucu) ─────────────────────────────────────────────
model EmbeddedEmission {
  id       String          @id @default(uuid()) @db.Uuid
  periodId String          @unique @map("period_id") @db.Uuid
  period   ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  scope2BaselineTco2  Float  @map("scope2_baseline_tco2")
  scope2VoltfoxTco2   Float  @map("scope2_voltfox_tco2")
  reductionTco2       Float  @map("reduction_tco2")
  reductionPct        Float  @map("reduction_pct")

  seeBaseline Float  @map("see_baseline")
  seeVoltfox  Float  @map("see_voltfox")

  defaultSee          Float? @map("default_see")
  savingsVsDefaultEur Float? @map("savings_vs_default_eur")

  calcEngineVersion String @map("calc_engine_version")
  calcMethodology   String @default("EU_2023_1773_AnnexIV_MethodA") @map("calc_methodology")
  efDataVersion     String @map("ef_data_version")

  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@map("embedded_emissions")
}

// ── CFEMatchingResult (24/7 CFE Eşleştirme Sonucu) ───────────────────────────
model CFEMatchingResult {
  id       String          @id @default(uuid()) @db.Uuid
  periodId String          @unique @map("period_id") @db.Uuid
  period   ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  totalConsumptionKwh Float @map("total_consumption_kwh")
  totalProductionKwh  Float @map("total_production_kwh")
  totalMatchedKwh     Float @map("total_matched_kwh")
  cfeScore            Float @map("cfe_score")
  ppaSurplusKwh       Float @map("ppa_surplus_kwh")
  ppaDeficitKwh       Float @map("ppa_deficit_kwh")
  matchedHours        Int   @map("matched_hours")
  partialHours        Int   @map("partial_hours")
  unmatchedHours      Int   @map("unmatched_hours")

  monthlyBreakdown  Json   @map("monthly_breakdown")
  gecDataVersion    String @map("gec_data_version")
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  @@map("cfe_matching_results")
}

// ── ShareLink ─────────────────────────────────────────────────────────────────
model ShareLink {
  id             String    @id @default(uuid()) @db.Uuid
  jti            String    @unique
  tenantId       String    @map("tenant_id") @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installationId String    @map("installation_id") @db.Uuid
  periodId       String    @map("period_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  password       String?   // scrypt hash: salt:hash
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([jti])
  @@map("share_links")
}

// ── ApiKey (Data Service B2B) ─────────────────────────────────────────────────
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  keyHash         String    @unique @map("key_hash")
  prefix          String
  scopes          String[]  @default([])
  expiresAt       DateTime? @map("expires_at")
  lastUsedAt      DateTime? @map("last_used_at")
  revokedAt       DateTime? @map("revoked_at")
  createdBy       String?   @map("created_by") @db.Uuid
  rateLimitPerMin Int?      @map("rate_limit_per_min") // null = global default (100)
  createdAt       DateTime  @default(now()) @map("created_at")

  requestLogs ApiRequestLog[]

  @@index([tenantId])
  @@map("api_keys")
}

// ── ApiRequestLog (API anahtar istek logu) ────────────────────────────────────
model ApiRequestLog {
  id          String   @id @default(uuid()) @db.Uuid
  apiKeyId    String   @map("api_key_id") @db.Uuid
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  tenantId    String   @map("tenant_id") @db.Uuid

  method      String
  endpoint    String
  statusCode  Int      @map("status_code")
  durationMs  Int      @map("duration_ms")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([apiKeyId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("api_request_logs")
}

// ── WebhookSubscription ───────────────────────────────────────────────────────
model WebhookSubscription {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url        String
  events     String[]
  secretHash String    @map("secret_hash")
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt    @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_subscriptions")
}

// ── WebhookDelivery ───────────────────────────────────────────────────────────
model WebhookDelivery {
  id             String              @id @default(uuid()) @db.Uuid
  subscriptionId String              @map("subscription_id") @db.Uuid
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  event          String
  payload        Json
  status         String    @default("pending")
  attempts       Int       @default(0)
  responseStatus Int?      @map("response_status")
  nextAttemptAt  DateTime? @map("next_attempt_at")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([status, nextAttemptAt])
  @@map("webhook_deliveries")
}

// ── AuditLog ──────────────────────────────────────────────────────────────────
model AuditLog {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String? @map("user_id") @db.Uuid

  action     String
  resource   String
  resourceId String? @map("resource_id")
  payload    Json?
  ipAddress  String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Notification ─────────────────────────────────────────────────────────────
model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id") @db.Uuid

  type       String
  title      String
  body       String?
  resource   String?
  resourceId String?  @map("resource_id") @db.Uuid
  read       Boolean  @default(false)

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ── NotificationPreference ────────────────────────────────────────────────────
model NotificationPreference {
  tenantId       String  @map("tenant_id") @db.Uuid
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String  @map("user_id") @db.Uuid

  calculationDone Boolean @default(true)  @map("calculation_done")
  cfeDone         Boolean @default(true)  @map("cfe_done")
  memberInvited   Boolean @default(true)  @map("member_invited")
  periodCreated   Boolean @default(true)  @map("period_created")
  emailEnabled    Boolean @default(false) @map("email_enabled")

  @@id([tenantId, userId])
  @@map("notification_preferences")
}

// ── EfImportLog ──────────────────────────────────────────────────────────────
model EfImportLog {
  id        String   @id @default(uuid()) @db.Uuid
  year      Int
  zoneId    String?  @map("zone_id")
  rowsAdded Int      @default(0) @map("rows_added")
  status    String   @default("ok")   // ok | error | partial
  message   String?
  startedAt DateTime @map("started_at")
  endedAt   DateTime @map("ended_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ef_import_logs")
}

// ── MemberInvite ─────────────────────────────────────────────────────────────
model MemberInvite {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email     String
  role      String    @default("viewer")
  token     String    @unique @default(uuid())
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("member_invites")
}

// ── EmissionTarget (Yıllık emisyon azaltım hedefleri) ────────────────────────
model EmissionTarget {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installationId String?       @map("installation_id") @db.Uuid
  installation   Installation? @relation(fields: [installationId], references: [id], onDelete: Cascade)
  year           Int
  metric         String        @default("see_voltfox") // see_voltfox | scope2_tco2 | reduction_pct
  targetValue    Decimal       @map("target_value") @db.Decimal(18, 6)
  baselineValue  Decimal?      @map("baseline_value") @db.Decimal(18, 6)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, installationId, year, metric])
  @@index([tenantId, year])
  @@map("emission_targets")
}

// ── CarbonPrice (EU ETS / CBAM fiyat geçmişi) ────────────────────────────────
model CarbonPrice {
  id          String   @id @default(uuid()) @db.Uuid
  date        DateTime @db.Date
  etsPriceEur Decimal  @map("ets_price_eur") @db.Decimal(10, 4)
  cbamEstEur  Decimal? @map("cbam_est_eur")  @db.Decimal(10, 4)
  source      String   @default("manual")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date, source])
  @@index([date(sort: Desc)])
  @@map("carbon_prices")
}

// ── CbamFacility (CBAM için izole tesis kaydı) ────────────────────────────────
model CbamFacility {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  facilityName         String   @map("facility_name")
  operator             String   @default("")
  facilityCountry      String   @map("facility_country")
  sector               String   @default("steel")   // cement|steel|aluminium|fertilizer|electricity|hydrogen|other
  facilityRef          String?  @map("facility_ref")
  unLoCode             String?  @map("un_lo_code")            // UN/LOCODE (CBAM teknik dosya zorunlu)
  cbamInstallationId   String?  @map("cbam_installation_id")  // CBAM portal tesis ID'si

  // Opsiyonel köprü — GEC/CFE tesisiyle bağlantı
  linkedInstallationId String?  @map("linked_installation_id") @db.Uuid

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt      @map("updated_at")

  products             CbamProduct[]

  @@index([tenantId])
  @@map("cbam_facilities")
}

// ── CbamProduct (CBAM tesisi altındaki ürün tanımı) ──────────────────────────
model CbamProduct {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  cbamFacilityId String       @map("cbam_facility_id") @db.Uuid
  facility       CbamFacility @relation(fields: [cbamFacilityId], references: [id], onDelete: Cascade)

  // Legacy soft-link (no FK constraint): veri geçişi izlenebilirliği için tutulur
  installationId String?      @map("installation_id") @db.Uuid

  productName          String  @map("product_name")
  cnCode               String? @map("cn_code")           // CBAM CN kodu: 7206, 7601, 2523, vb.
  description          String?
  unit                 String  @default("tonne") @map("unit") // tonne | MWh | kg
  isCbamScope          Boolean @default(true) @map("is_cbam_scope")

  // "facility" → tesisin toplam yenilenebilir üretimi ürünler arasında orantılı dağıtılır
  // "band"     → her üretim bandı kendi enerji sayacına sahip, doğrudan atanır
  energyAllocationMode String  @default("facility") @map("energy_allocation_mode")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt    @map("updated_at")

  productPeriods CbamProductPeriod[]

  @@index([cbamFacilityId])
  @@index([tenantId])
  @@map("cbam_products")
}

// ── CbamProductPeriod (Ürün bazlı dönem verisi + hesaplama sonucu) ───────────
model CbamProductPeriod {
  id            String      @id @default(uuid()) @db.Uuid
  cbamProductId String      @map("cbam_product_id") @db.Uuid
  cbamProduct   CbamProduct @relation(fields: [cbamProductId], references: [id], onDelete: Cascade)

  reportYear  Int      @map("report_year")
  periodName  String   @map("period_name")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date")   @db.Date

  // Üretim
  productionVolumeTonne Decimal @map("production_volume_tonne") @db.Decimal(18, 4)

  // Scope 1 (doğrudan yakıt emisyonu vb.)
  scope1DirectTco2 Decimal @default(0) @map("scope1_direct_tco2") @db.Decimal(18, 4)
  scope1AuditNote  String? @map("scope1_audit_note")

  // ── BAND modu: üretim bandına özel sayaç verisi ──────────────────────────
  bandElectricityKwh Decimal? @map("band_electricity_kwh") @db.Decimal(18, 2)
  bandRenewableKwh   Decimal? @map("band_renewable_kwh")   @db.Decimal(18, 2)

  // ── FACILITY modu: tesis toplamları + bu ürünün payı ─────────────────────
  facilityTotalKwh     Decimal? @map("facility_total_kwh")     @db.Decimal(18, 2) // tüm tesis toplam elektrik
  facilityRenewableKwh Decimal? @map("facility_renewable_kwh") @db.Decimal(18, 2) // tüm tesis toplam yenilenebilir
  productShareKwh      Decimal? @map("product_share_kwh")      @db.Decimal(18, 2) // bu ürün bandının elektrik payı

  // Yenilenebilir kaynak
  // "solar" | "wind_onshore" | "wind_offshore" | "hydro" | "nuclear" | "biomass" | "geothermal"
  renewableSource   String?  @map("renewable_source")
  renewableSourceEf Decimal? @map("renewable_source_ef") @db.Decimal(10, 6) // tCO₂/MWh (auto-filled)

  // Referans EF'ler — eşleşmeyen kısım için
  cbamDefaultEf Decimal? @map("cbam_default_ef") @db.Decimal(10, 6) // CBAM Annex IV elektrik EF'i (tCO₂/MWh)
  countryGridEf Decimal? @map("country_grid_ef") @db.Decimal(10, 6) // Ülke yıllık ortalama EF (tCO₂/MWh)

  // ── Hesaplama sonuçları (calculate endpoint tarafından doldurulur) ────────
  allocatedElecKwh      Decimal? @map("allocated_elec_kwh")       @db.Decimal(18, 2)
  allocatedRenewKwh     Decimal? @map("allocated_renew_kwh")      @db.Decimal(18, 2)
  matchedKwh            Decimal? @map("matched_kwh")              @db.Decimal(18, 2)
  unmatchedKwh          Decimal? @map("unmatched_kwh")            @db.Decimal(18, 2)
  matchedIndirectTco2   Decimal? @map("matched_indirect_tco2")    @db.Decimal(18, 6)
  unmatchedIndirectTco2 Decimal? @map("unmatched_indirect_tco2")  @db.Decimal(18, 6)
  totalIndirectTco2     Decimal? @map("total_indirect_tco2")      @db.Decimal(18, 6)
  totalEmbeddedTco2     Decimal? @map("total_embedded_tco2")      @db.Decimal(18, 6)
  see                   Decimal? @map("see")                      @db.Decimal(18, 8) // tCO₂/tonne
  effectiveEf           Decimal? @map("effective_ef")             @db.Decimal(10, 6) // ağırlıklı ort. tCO₂/MWh
  unmatchedEfUsed       Decimal? @map("unmatched_ef_used")        @db.Decimal(10, 6)
  unmatchedEfSource     String?  @map("unmatched_ef_source")      // "cbam_default" | "country_grid"

  calculatedAt DateTime? @map("calculated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([cbamProductId, reportYear])
  @@index([cbamProductId])
  @@map("cbam_product_periods")
}

// ── HourlyConsumption (Saatlik Tüketim Verisi) ───────────────────────────────
model HourlyConsumption {
  id             String          @id @default(uuid()) @db.Uuid
  periodId       String          @map("period_id") @db.Uuid
  period         ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  hour           DateTime        @map("hour")           // ISO 8601 UTC, saat başı
  consumptionKwh Float           @map("consumption_kwh")
  source         String          @default("csv")        // csv | osos | amr | manual
  quality        String          @default("measured")   // measured | estimated | interpolated

  createdAt      DateTime        @default(now()) @map("created_at")

  @@unique([periodId, hour])
  @@index([periodId])
  @@index([hour])
  @@map("hourly_consumptions")
}

// ── IntegrationConfig (Tenant bazlı entegrasyon yapılandırmaları) ────────────
model IntegrationConfig {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key           String               // 'entso-e' | 'epias' | 'cbam-terminal' | ...
  enabled       Boolean  @default(false)
  configEnc     Json     @default("{}") @map("config_enc") // hassas alanlar app katmanında şifrelenir
  status        String   @default("disconnected") // connected|disconnected|error|beta|coming_soon
  lastTestedAt  DateTime? @map("last_tested_at")
  testMessage   String?   @map("test_message")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("integration_configs")
}

// ── MarketPrice (DAM fiyatları — gerçekleşen + tahmin) ───────────────────────
model MarketPrice {
  id            String   @id @default(uuid()) @db.Uuid
  zoneId        String   @map("zone_id")
  hour          DateTime
  priceEurMwh   Float?   @map("price_eur_mwh")
  priceTryMwh   Float?   @map("price_try_mwh")
  currency      String   @default("EUR")
  priceType     String   @map("price_type")    // dam_actual | dam_forecast | intraday
  source        String                          // entso-e | epias | model
  forecastMadeAt DateTime? @map("forecast_made_at")
  confidenceLow  Float?   @map("confidence_low")
  confidenceHigh Float?   @map("confidence_high")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([zoneId, hour, priceType, source])
  @@index([zoneId, hour(sort: Desc)])
  @@index([priceType, hour(sort: Desc)])
  @@map("market_prices")
}

// ── GenerationForecast (Yenilenebilir üretim — actual + forecast) ─────────────
model GenerationForecast {
  id            String   @id @default(uuid()) @db.Uuid
  zoneId        String   @map("zone_id")
  hour          DateTime
  psrType       String   @map("psr_type")      // B16=solar, B19=wind_onshore, B18=wind_offshore, B10=hydro, TOTAL_LOAD
  recordType    String   @map("record_type")   // actual | forecast
  quantityMw    Float    @map("quantity_mw")
  source        String                          // entso-e | open-meteo | model
  forecastMadeAt DateTime? @map("forecast_made_at")
  confidenceLow  Float?   @map("confidence_low")
  confidenceHigh Float?   @map("confidence_high")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([zoneId, hour, psrType, recordType, source])
  @@index([zoneId, hour(sort: Desc), psrType])
  @@index([psrType, zoneId, hour(sort: Desc)])
  @@map("generation_forecasts")
}

// ── WeatherSnapshot (Open-Meteo önbelleği) ────────────────────────────────────
model WeatherSnapshot {
  id               String   @id @default(uuid()) @db.Uuid
  lat              Float
  lon              Float
  hour             DateTime
  ghiWm2           Float?   @map("ghi_wm2")          // Global Horizontal Irradiance W/m²
  dhiWm2           Float?   @map("dhi_wm2")          // Diffuse Horizontal Irradiance W/m²
  windSpeed10m     Float?   @map("wind_speed_10m")
  windSpeed100m    Float?   @map("wind_speed_100m")
  windDirection10m Float?   @map("wind_direction_10m")
  temperature2m    Float?   @map("temperature_2m")
  cloudCover       Float?   @map("cloud_cover")
  precipitation    Float?
  source           String   @default("open-meteo")
  forecastMadeAt   DateTime? @map("forecast_made_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([lat, lon, hour(sort: Desc)])
  @@index([hour(sort: Desc)])
  @@map("weather_snapshots")
}

// ── CiForecast (24–48 saatlik karbon yoğunluğu tahmini) ──────────────────────
model CiForecast {
  id                 String   @id @default(uuid()) @db.Uuid
  zoneId             String   @map("zone_id")
  hour               DateTime
  ciGco2Kwh          Float    @map("ci_gco2_kwh")
  ciActualGco2Kwh    Float?   @map("ci_actual_gco2_kwh")  // Gerçekleşen — sonradan doldurulur
  method             String   @default("generation-mix")   // generation-mix | statistical
  horizonH           Int      @map("horizon_h")            // Kaç saat öncesinden tahmin
  mae                Float?                                 // Mean Absolute Error
  forecastMadeAt     DateTime @map("forecast_made_at")
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([zoneId, hour, method, forecastMadeAt])
  @@index([zoneId, hour(sort: Desc)])
  @@index([zoneId, horizonH, hour(sort: Desc)])
  @@map("ci_forecasts")
}

// ── DataImportJob (Cron job çalışma logu) ────────────────────────────────────
model DataImportJob {
  id            String   @id @default(uuid()) @db.Uuid
  jobType       String   @map("job_type")  // dam-prices | generation-forecast | weather | ci-forecast | load-forecast | ef-actual
  zoneId        String?  @map("zone_id")
  status        String   @default("running") // running | success | error | partial
  startedAt     DateTime @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  rowsInserted  Int      @default(0) @map("rows_inserted")
  errorMessage  String?  @map("error_message")
  metadata      Json     @default("{}") @map("metadata")

  @@index([jobType, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
  @@map("data_import_jobs")
}

// ── EsgPlaygroundGraph (ESG Dijital İkiz Canvas) ─────────────────────────────
model EsgPlaygroundGraph {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name             String   @default("Yeni Canvas")
  description      String?
  nodesJson        Json     @default("[]") @map("nodes_json")
  edgesJson        Json     @default("[]") @map("edges_json")
  viewport         Json     @default("{\"x\":0,\"y\":0,\"zoom\":1}")
  createdBy        String   @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid

  isTemplate       Boolean  @default(false) @map("is_template")
  templateKey      String?  @unique @map("template_key")
  templateCategory String?  @map("template_category")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt      @map("updated_at")

  snapshots        EsgPlaygroundSnapshot[]

  @@index([tenantId])
  @@index([isTemplate])
  @@map("esg_playground_graphs")
}

// ── EsgPlaygroundSnapshot (Denetim Anlık Görüntüsü — değiştirilemez) ─────────
model EsgPlaygroundSnapshot {
  id               String             @id @default(uuid()) @db.Uuid
  graphId          String             @map("graph_id") @db.Uuid
  graph            EsgPlaygroundGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  name             String
  reportingPeriod  String?            @map("reporting_period")  // "Q1 2025" | "FY 2025"
  nodesJson        Json               @map("nodes_json")
  edgesJson        Json               @map("edges_json")
  hash             String             // SHA-256 of nodesJson+edgesJson
  isLocked         Boolean            @default(true) @map("is_locked")
  methodologyVer   String             @default("1.0") @map("methodology_ver")
  createdBy        String             @map("created_by") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")

  @@index([graphId])
  @@map("esg_playground_snapshots")
}

// ── SmtpConfig (Sistem geneli tek kayıt — singleton id="default") ─────────────
model SmtpConfig {
  id          String  @id @default("default")
  host        String
  port        Int     @default(587)
  secure      Boolean @default(false) // true = TLS (465), false = STARTTLS (587)
  username    String?
  passwordEnc String? @map("password_enc") // AES-256-GCM şifreli (veya plain — env key gerekir)
  fromEmail   String  @map("from_email")
  fromName    String  @default("Voltfox") @map("from_name")
  enabled     Boolean @default(true)
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by") @db.Uuid

  @@map("smtp_config")
}
